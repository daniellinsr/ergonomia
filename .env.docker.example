# ====================================
# Variáveis de Ambiente - Sistema de Ergonomia
# ====================================
# Copie este arquivo para .env e preencha com os valores corretos
# Uso: cp .env.docker.example .env

# ====================================
# Database (PostgreSQL)
# ====================================
DB_NAME=ergonomia_db
DB_USER=ergonomia_user
DB_PASSWORD=ALTERE_SENHA_FORTE_AQUI

# ====================================
# JWT Secrets
# ====================================
# IMPORTANTE: Gerar chaves secretas únicas e fortes!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=GERAR_CHAVE_SECRETA_64_CARACTERES_AQUI
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=GERAR_OUTRA_CHAVE_SECRETA_64_CARACTERES_AQUI
JWT_REFRESH_EXPIRES_IN=7d

# ====================================
# Traefik - Roteamento e SSL
# ====================================
# Domínio da aplicação (usado pelo Traefik)
TRAEFIK_HOST=ergonomia.helthcorp.com.br

# ====================================
# Frontend
# ====================================
FRONTEND_URL=https://ergonomia.helthcorp.com.br
VITE_API_URL=/api

# ====================================
# Rate Limiting
# ====================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ====================================
# NOTAS IMPORTANTES
# ====================================
# 1. Este setup assume que você já tem Traefik rodando com:
#    - Rede externa chamada 'web'
#    - Entrypoints 'web' (HTTP:80) e 'websecure' (HTTPS:443)
#    - Certresolver 'lets-encrypt' configurado
#
# 2. O Traefik irá:
#    - Redirecionar automaticamente HTTP para HTTPS
#    - Gerar certificado SSL via Let's Encrypt
#    - Rotear tráfego para o container frontend
#
# 3. Certifique-se de que o domínio está apontando para o servidor
