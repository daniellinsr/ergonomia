# Backend - Production Environment Variables
# Copie este arquivo para .env no servidor e preencha com os valores corretos

NODE_ENV=production
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ergonomia_db
DB_USER=ergonomia_user
DB_PASSWORD=ALTERAR_SENHA_FORTE_AQUI

# JWT - IMPORTANTE: Gerar chaves secretas únicas e fortes!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERAR_CHAVE_SECRETA_64_CARACTERES
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=GERAR_OUTRA_CHAVE_SECRETA_64_CARACTERES
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=https://ergonomia.helthcorp.com.br

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Opcional: Sentry para monitoramento de erros
# SENTRY_DSN=

# Opcional: Email (se implementar notificações)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
